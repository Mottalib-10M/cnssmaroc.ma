---
import Layout from '../components/layout/Layout.astro';

const title = 'Page introuvable : calculateur cotisations CNSS Maroc';
const description = 'La page demandée n\'existe pas ou a été déplacée. Retrouvez nos calculateurs CNSS, simulateurs de retraite et guides sur la protection sociale au Maroc.';
---

<Layout title={title} description={description} noindex={true}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-6xl font-bold text-brand-600 mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">Page non trouvée</h1>
    <p class="text-gray-600 mb-8">
      La page que vous recherchez n'existe pas ou a été déplacée.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/" class="inline-flex items-center px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors">
        Retour à l'accueil
      </a>
      <a href="/calculateur-cotisations-cnss/" class="inline-flex items-center px-6 py-3 bg-white text-brand-700 font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors">
        Calculateur CNSS
      </a>
    </div>
  </div>
</Layout>
