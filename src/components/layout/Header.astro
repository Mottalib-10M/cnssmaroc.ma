---
import { CONFIG } from '../../config';

const navItems = [
  { label: 'Cotisations', href: '/calculateur-cotisations-cnss/' },
  { label: 'Retraite', href: '/simulateur-retraite-cnss/' },
  { label: 'TVA', href: '/calculateur-tva/' },
  { label: 'Allocations', href: '/calculateur-allocations-familiales/' },
  { label: 'Guides', href: '/guides/cotisations-cnss-maroc/' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-brand-700 hover:text-brand-600 transition-colors">
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="#059669"/>
          <path d="M8 16C8 11.58 11.58 8 16 8C20.42 8 24 11.58 24 16C24 20.42 20.42 24 16 24" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M16 13V17L19 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {CONFIG.siteName}
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="Navigation principale">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              currentPath.startsWith(item.href)
                ? 'text-brand-700 bg-brand-50'
                : 'text-gray-600 hover:text-brand-700 hover:bg-gray-50',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <button
        type="button"
        class="md:hidden p-2 text-gray-600 hover:text-brand-700 rounded-lg"
        aria-label="Ouvrir le menu"
        id="mobile-menu-btn"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    class="md:hidden hidden border-t border-gray-200 bg-white"
    id="mobile-menu"
    aria-label="Navigation mobile"
  >
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block px-3 py-2 text-sm font-medium rounded-lg transition-colors',
            currentPath.startsWith(item.href)
              ? 'text-brand-700 bg-brand-50'
              : 'text-gray-600 hover:text-brand-700 hover:bg-gray-50',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
