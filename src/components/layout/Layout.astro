---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { CONFIG } from '../../config';
import { buildWebSiteSchema } from '../../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const { title, description, canonical, schema, noindex = false } = Astro.props;
const pageUrl = canonical || Astro.url.href;
const websiteSchema = buildWebSiteSchema();
const allSchemas = schema
  ? Array.isArray(schema)
    ? [websiteSchema, ...schema]
    : [websiteSchema, schema]
  : [websiteSchema];
---

<!doctype html>
<html lang={CONFIG.lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={CONFIG.locale} />
    <meta property="og:site_name" content={CONFIG.siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="author" content={CONFIG.author.name} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={CONFIG.brand.primary} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
