---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { CONFIG } from '../../config';
import { buildWebSiteSchema, buildOrganizationSchema } from '../../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const { title, description, canonical, schema, noindex = false } = Astro.props;
const pageUrl = canonical || Astro.url.href;
const ogImage = CONFIG.siteUrl + '/og-default.png';
const websiteSchema = buildWebSiteSchema();
const organizationSchema = buildOrganizationSchema();
const allSchemas = schema
  ? Array.isArray(schema)
    ? [websiteSchema, organizationSchema, ...schema]
    : [websiteSchema, organizationSchema, schema]
  : [websiteSchema, organizationSchema];
---

<!doctype html>
<html lang={CONFIG.lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={CONFIG.locale} />
    <meta property="og:site_name" content={CONFIG.siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="CNSS Maroc - Calculateur cotisations et retraite" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="author" content={CONFIG.author.name} />
    <meta name="google-site-verification" content="GOOGLE_VERIFICATION_CODE" />
    <meta name="msvalidate.01" content="BING_VERIFICATION_CODE" />
    <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={CONFIG.brand.primary} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-teal-600 focus:rounded focus:shadow-lg">
      Aller au contenu
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Clarity analytics (deferred 3s) -->
    <script is:inline>
      setTimeout(function(){
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window,document,"clarity","script","CLARITY_PROJECT_ID");
      },3000);
    </script>
  </body>
</html>
